            "format": "uri"
          },
          "basePrice": {
            "type": "integer",
            "minimum": 0,
            "description": "Price in paise (₹599 = 59900)"
          },
          "durationMinutes": {
            "type": "integer",
            "exclusiveMinimum": 0
          },
          "includes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "faq": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "question": {
                  "type": "string",
                  "minLength": 1
                },
                "answer": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "question",
                "answer"
              ]
            }
          },
          "addOns": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "price": {
                  "type": "integer",
                  "minimum": 0
                },
                "triggerCondition": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "id",
                "name",
                "price",
                "triggerCondition"
              ]
