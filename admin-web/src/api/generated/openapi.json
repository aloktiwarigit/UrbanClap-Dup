{
  "openapi": "3.1.0",
  "info": {
    "title": "homeservices-api",
    "version": "0.1.0",
    "description": "homeservices-mvp internal API. Generated from Zod schemas — do not hand-edit.",
    "contact": {
      "name": "homeservices-mvp maintainers",
      "url": "https://github.com/aloktiwarigit/Urbanclap-dup"
    }
  },
  "servers": [
    {
      "url": "http://localhost:7071/api",
      "description": "Local Azure Functions runtime"
    }
  ],
  "tags": [
    {
      "name": "system",
      "description": "Operational / liveness endpoints"
    }
  ],
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ]
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "commit": {
            "type": "string",
            "minLength": 1
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "uptimeSeconds": {
            "type": "number",
            "minimum": 0
          }
        },
        "required": [
          "status",
          "version",
          "commit",
          "timestamp",
          "uptimeSeconds"
        ],
        "additionalProperties": false
      },
      "ServiceCard": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9-]+$",
            "example": "ac-deep-clean"
          },
          "categoryId": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "shortDescription": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "heroImageUrl": {
            "type": "string",
            "format": "uri"
          },
          "basePrice": {
            "type": "integer",
            "minimum": 0,
            "description": "Price in paise (₹599 = 59900)"
          },
          "durationMinutes": {
            "type": "integer",
            "exclusiveMinimum": 0
          }
        },
        "required": [
          "id",
          "categoryId",
          "name",
          "shortDescription",
          "heroImageUrl",
          "basePrice",
          "durationMinutes"
        ]
      },
      "ServiceDetail": {
        "type": "object",
