{
  "openapi": "3.1.0",
  "info": {
    "title": "homeservices-api",
    "version": "0.1.0",
    "description": "homeservices-mvp internal API. Generated from Zod schemas — do not hand-edit.",
    "contact": {
      "name": "homeservices-mvp maintainers",
      "url": "https://github.com/aloktiwarigit/Urbanclap-dup"
    }
  },
  "servers": [
    {
      "url": "http://localhost:7071/api",
      "description": "Local Azure Functions runtime"
    }
  ],
  "tags": [
    {
      "name": "system",
      "description": "Operational / liveness endpoints"
    }
  ],
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ]
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "commit": {
            "type": "string",
            "minLength": 1
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "uptimeSeconds": {
            "type": "number",
            "minimum": 0
          }
        },
        "required": [
          "status",
          "version",
          "commit",
          "timestamp",
          "uptimeSeconds"
        ],
        "additionalProperties": false
      },
      "DashboardSummary": {
        "type": "object",
        "properties": {
          "bookingsToday": {
            "type": "integer",
            "minimum": 0
          },
          "gmvToday": {
            "type": "integer",
            "minimum": 0
          },
          "commissionToday": {
            "type": "integer",
            "minimum": 0
          },
          "payoutsPending": {
            "type": "integer",
            "minimum": 0
          },
          "complaintsOpen": {
            "type": "integer",
            "minimum": 0
          },
          "techsOnDuty": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": [
          "bookingsToday",
          "gmvToday",
          "commissionToday",
          "payoutsPending",
          "complaintsOpen",
          "techsOnDuty"
        ],
        "additionalProperties": false
      },
      "DashboardSummaryResponse": {
        "type": "object",
        "properties": {
          "summary": {
            "$ref": "#/components/schemas/DashboardSummary"
          }
        },
        "required": [
          "summary"
        ]
      },
      "BookingEvent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "bookingId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "customerId": {
            "type": "string"
          },
          "technicianId": {
            "type": "string"
          },
          "serviceId": {
            "type": "string"
          },
          "amount": {
            "type": "integer",
            "minimum": 0
          },
          "createdAt": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "booking",
              "assigned",
              "completed",
              "alert",
              "payout",
              "complaint"
            ]
          },
          "title": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "bookingId",
          "status",
          "customerId",
          "serviceId",
          "amount",
          "createdAt",
          "kind",
          "title"
        ]
      },
      "BookingEventsResponse": {
        "type": "object",
        "properties": {
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BookingEvent"
            }
          },
          "total": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": [
          "events",
          "total"
        ]
      },
      "TechLocation": {
        "type": "object",
        "properties": {
          "technicianId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "serviceType": {
            "type": "string"
          },
          "lat": {
            "type": "number"
          },
          "lng": {
            "type": "number"
          },
          "state": {
            "type": "string",
            "enum": [
              "active",
              "enroute",
              "idle",
              "alert"
            ]
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "technicianId",
          "lat",
          "lng",
          "state",
          "updatedAt"
        ]
      },
      "TechLocationsResponse": {
        "type": "object",
        "properties": {
          "techs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TechLocation"
            }
          }
        },
        "required": [
          "techs"
        ]
      },
      "AdminLoginRequest": {
        "type": "object",
        "properties": {
          "idToken": {
            "type": "string",
            "minLength": 1
          },
          "totpCode": {
            "type": "string",
            "pattern": "^\\d{6}$"
          }
        },
        "required": [
          "idToken"
        ]
      },
      "AdminSetupTotpVerifyRequest": {
        "type": "object",
        "properties": {
          "totpCode": {
            "type": "string",
            "pattern": "^\\d{6}$"
          }
        },
        "required": [
          "totpCode"
        ]
      },
      "AdminMeResponse": {
        "type": "object",
        "properties": {
          "adminId": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        },
        "required": [
          "adminId",
          "email",
          "role"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/v1/health": {
      "get": {
        "operationId": "getHealth",
        "tags": [
          "system"
        ],
        "summary": "Liveness probe",
        "description": "Returns api/ liveness status plus build metadata. Unauthenticated. Never touches the database.",
        "responses": {
          "200": {
            "description": "Service is live",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/admin/dashboard/summary": {
      "get": {
        "operationId": "adminGetDashboardSummary",
        "tags": [
          "dashboard"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "summary": "Today's live operations KPI counters",
        "responses": {
          "200": {
            "description": "Dashboard summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DashboardSummaryResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated"
          },
          "403": {
            "description": "Forbidden"
          },
          "502": {
            "description": "Upstream Cosmos error"
          }
        }
      }
    },
    "/v1/admin/dashboard/feed": {
      "get": {
        "operationId": "adminGetDashboardFeed",
        "tags": [
          "dashboard"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "summary": "Recent 50 booking events, newest first",
        "responses": {
          "200": {
            "description": "Booking events feed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BookingEventsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated"
          },
          "403": {
            "description": "Forbidden"
          },
          "502": {
            "description": "Upstream Cosmos error"
          }
        }
      }
    },
    "/v1/admin/dashboard/tech-locations": {
      "get": {
        "operationId": "adminGetTechLocations",
        "tags": [
          "dashboard"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "summary": "Active technician map pin positions",
        "responses": {
          "200": {
            "description": "Tech locations",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TechLocationsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated"
          },
          "403": {
            "description": "Forbidden"
          },
          "502": {
            "description": "Upstream Cosmos error"
          }
        }
      }
    },
    "/v1/admin/auth/login": {
      "post": {
        "operationId": "adminLogin",
        "tags": [
          "admin-auth"
        ],
        "summary": "Email + password + TOTP login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdminLoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login success or setup required"
          }
        }
      }
    },
    "/v1/admin/auth/setup-totp": {
      "get": {
        "operationId": "adminSetupTotpGet",
        "tags": [
          "admin-auth"
        ],
        "summary": "Get TOTP enrollment QR code",
        "responses": {
          "200": {
            "description": "QR code data URI"
          }
        }
      },
      "post": {
        "operationId": "adminSetupTotpPost",
        "tags": [
          "admin-auth"
        ],
        "summary": "Complete TOTP enrollment",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdminSetupTotpVerifyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Enrollment complete, session cookies set"
          }
        }
      }
    },
    "/v1/admin/auth/refresh": {
      "post": {
        "operationId": "adminRefresh",
        "tags": [
          "admin-auth"
        ],
        "summary": "Refresh access token",
        "responses": {
          "200": {
            "description": "New hs_access cookie set"
          }
        }
      }
    },
    "/v1/admin/auth/logout": {
      "post": {
        "operationId": "adminLogout",
        "tags": [
          "admin-auth"
        ],
        "summary": "Invalidate session",
        "responses": {
          "200": {
            "description": "Cookies cleared"
          }
        }
      }
    },
    "/v1/admin/me": {
      "get": {
        "operationId": "adminMe",
        "tags": [
          "admin-auth"
        ],
        "summary": "Current admin profile",
        "responses": {
          "200": {
            "description": "Admin profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdminMeResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {}
}
