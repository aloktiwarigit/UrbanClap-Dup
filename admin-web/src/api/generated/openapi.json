          },
          "photoStages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "required": {
                  "type": "boolean"
                }
              },
              "required": [
                "id",
                "label",
                "required"
              ]
            }
          },
          "isActive": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "categoryId",
          "name",
          "shortDescription",
          "heroImageUrl",
          "basePrice",
          "durationMinutes",
          "includes",
          "faq",
          "addOns",
          "photoStages",
          "isActive"
        ]
      },
