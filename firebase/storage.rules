rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // KYC documents — each user owns their own subtree
    match /kyc/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Job site photos — technician UID is embedded in the path so the rule
    // can verify the uploading user matches the path without a Cosmos lookup.
    // Path: bookings/{bookingId}/photos/{technicianUid}/{stage}/{file}
    match /bookings/{bookingId}/photos/{technicianUid}/{stage}/{file} {
      allow write: if request.auth != null
                   && request.auth.uid == technicianUid
                   && request.resource.size <= 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      // Admin and the assigned customer read via their own API-issued tokens
      allow read: if request.auth != null;
    }
  }
}
