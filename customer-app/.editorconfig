root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_size = 4
# Allow PascalCase for @Composable functions (Jetpack Compose convention)
ktlint_function_naming_ignore_when_annotated_with = Composable
# Allow explicit ': Unit' return types (required by -Xexplicit-api=strict + Codex review)
ktlint_standard_no-unit-return = disabled

[*.md]
trim_trailing_whitespace = false
