{
  "name": "homeservices-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@growthbook/growthbook": "^1",
    "@sentry/node": "^8",
    "@opentelemetry/api": "^1",
    "@opentelemetry/auto-instrumentations-node": "^0.50",
    "fastify": "^5",
    "posthog-node": "^4",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@vitest/coverage-v8": "^2",
    "eslint": "^9",
    "supertest": "^7",
    "testcontainers": "^10",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^2"
  }
}
